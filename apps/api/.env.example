# ── Banco de dados ────────────────────────────────────────────
# Em produção (Railway): gerado automaticamente ao criar o PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── Autenticação ──────────────────────────────────────────────
# Gerar em produção: openssl rand -hex 64
JWT_SECRET="TROQUE-POR-UMA-STRING-ALEATORIA-FORTE"

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS — domínio do frontend ────────────────────────────────
CORS_ORIGIN=https://seu-projeto.vercel.app

# ── Email (lembretes de vacina, portal do tutor) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
# Para Gmail: usar "Senha de App" (não a senha normal)
# https://myaccount.google.com/apppasswords
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── IA (opcional — transcrição de consultas) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telemedicina (opcional) ───────────────────────────────────
DAILY_API_KEY=

# ── Fiscal NF-e (opcional) ───────────────────────────────────
NUVEM_FISCAL_CLIENT_ID=
NUVEM_FISCAL_CLIENT_SECRET=

# ── Billing / Asaas ──────────────────────────────────────────
# Criar conta em https://www.asaas.com
# Sandbox: https://sandbox.asaas.com (para desenvolvimento)
ASAAS_API_KEY=
ASAAS_ENV=sandbox        # sandbox | production
# Token configurado em: painel Asaas → Configurações → Integrações → Webhook
ASAAS_WEBHOOK_TOKEN=

# URL pública do app (usada nos emails de expiração de trial)
APP_URL=https://seu-projeto.vercel.app
